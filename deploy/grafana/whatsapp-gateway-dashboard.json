{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "type": "stat",
      "title": "Connected instances",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "whatsapp_gateway_instances{status=\"connected\"}",
          "legendFormat": "Connected",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Messages (24h)",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "whatsapp_gateway_messages_last_24h",
          "legendFormat": "Messages",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Redis",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Offline", "color": "red" },
                "1": { "text": "Online", "color": "green" }
              }
            }
          ]
        }
      },
      "targets": [
        {
          "expr": "whatsapp_gateway_redis_connected",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Dead-letter webhooks",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "whatsapp_gateway_queue_records{queue=\"webhooks\",status=\"failed\"}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Webhook and AI latency",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "whatsapp_gateway_webhook_latency_ms{stat=\"average\"}",
          "legendFormat": "Webhook average",
          "refId": "A"
        },
        {
          "expr": "whatsapp_gateway_ai_latency_ms{stat=\"average\"}",
          "legendFormat": "AI average",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queue records",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "whatsapp_gateway_queue_records",
          "legendFormat": "{{queue}} / {{status}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["whatsapp", "gateway", "baileys"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "WhatsApp Gateway",
  "uid": "whatsapp-gateway"
}
