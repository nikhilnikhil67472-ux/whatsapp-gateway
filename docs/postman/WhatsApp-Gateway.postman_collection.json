{
  "info": {
    "_postman_id": "fbe73598-785a-4ad6-8d34-c94c332bf550",
    "name": "WhatsApp AI Gateway",
    "description": "Core health, outbound messaging, and dashboard instance operations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "apiKey", "value": "" },
    { "key": "instanceId", "value": "support" },
    { "key": "phoneNumber", "value": "919876543210" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "health"]
        }
      }
    },
    {
      "name": "Send text",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{apiKey}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"instanceId\": \"{{instanceId}}\",\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"type\": \"text\",\n  \"text\": \"Hello from Postman\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/whatsapp/send",
          "host": ["{{baseUrl}}"],
          "path": ["api", "whatsapp", "send"]
        }
      }
    },
    {
      "name": "Send media URL",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{apiKey}}", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"instanceId\": \"{{instanceId}}\",\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"type\": \"media\",\n  \"mediaUrl\": \"https://example.com/invoice.pdf\",\n  \"mediaType\": \"document\",\n  \"mimeType\": \"application/pdf\",\n  \"fileName\": \"invoice.pdf\",\n  \"text\": \"Your invoice\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/whatsapp/send",
          "host": ["{{baseUrl}}"],
          "path": ["api", "whatsapp", "send"]
        }
      }
    },
    {
      "name": "OpenAPI document",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/openapi",
          "host": ["{{baseUrl}}"],
          "path": ["api", "openapi"]
        }
      }
    }
  ]
}
