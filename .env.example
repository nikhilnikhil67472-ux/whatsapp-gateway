# Core persistence and public URL
SQLITE_DB_PATH=./data/gateway.db
WHATSAPP_SESSION_ROOT=./data/whatsapp-sessions
BAILEYS_DELETE_LEGACY_AUTH_AFTER_MIGRATION=false
APP_BASE_URL=http://localhost:3000

# Required in production
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
AUTH_SECRET=replace-with-at-least-32-random-characters
DASHBOARD_PASSWORD=replace-with-a-strong-dashboard-password
GATEWAY_API_KEY=replace-with-a-long-random-admin-api-key
ALLOW_INSECURE_API=false
ADMIN_EMAIL=admin@localhost
ADMIN_NAME=Administrator

# Temporary public judging mode. This bypasses dashboard and API auth only on the exact host.
HACKATHON_PUBLIC_MODE=false
HACKATHON_PUBLIC_HOST=

# API and login security
API_RATE_LIMIT_PER_MINUTE=120
DASHBOARD_LOGIN_RATE_LIMIT_PER_MINUTE=10
API_IP_ALLOWLIST=

# Redis and BullMQ (optional; SQLite polling remains the fallback)
REDIS_URL=
REDIS_REQUIRED=false
NODE_ID=
OUTBOUND_QUEUE_CONCURRENCY=10
WEBHOOK_QUEUE_CONCURRENCY=20
WORKER_POLL_INTERVAL_MS=2000

# AI providers and media intelligence
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TRANSCRIPTION_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
DEFAULT_AI_SYSTEM_PROMPT=
AI_PROVIDER_TIMEOUT_MS=60000
AI_MAX_OUTPUT_TOKENS=1000
TRANSCRIPTION_LANGUAGE=
MAX_EXTRACTED_DOCUMENT_CHARS=100000

# S3 or MinIO media storage (optional)
MEDIA_STORAGE_PROVIDER=local
MEDIA_STORAGE_REQUIRED=false
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_SIGNED_URL_TTL_SECONDS=86400
S3_SERVER_SIDE_ENCRYPTION=AES256

# Media and webhook limits
MAX_INBOUND_MEDIA_BYTES=20971520
MAX_OUTBOUND_MEDIA_BYTES=26214400
WEBHOOK_TIMEOUT_MS=15000
MEDIA_FETCH_TIMEOUT_MS=20000
MEDIA_ALLOWED_HOSTS=
OPT_OUT_CONFIRMATION_TEXT=
OPT_IN_CONFIRMATION_TEXT=

# Reliability and retention
BAILEYS_LOG_LEVEL=warn
LOG_LEVEL=info
INSTANCE_HEALTH_INTERVAL_MS=30000
ZOMBIE_SOCKET_TIMEOUT_MS=90000
DATA_RETENTION_DAYS=30
MAINTENANCE_INTERVAL_MS=21600000

# Prometheus and Sentry (optional)
METRICS_TOKEN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
