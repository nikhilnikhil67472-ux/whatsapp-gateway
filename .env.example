# Optional: where the local SQLite database is stored
SQLITE_DB_PATH=./data/gateway.db

# Optional: legacy session folder. Existing files are migrated into SQLite on first use.
WHATSAPP_SESSION_ROOT=./data/whatsapp-sessions

# Required for n8n/cloud AI agents to download media.
# Use your public app URL, ngrok URL, Cloudflare Tunnel URL, or VPS domain.
APP_BASE_URL=http://localhost:3000

# Required when n8n bearer secrets are configured
ENCRYPTION_KEY=exactly-32-characters-long-key!!

# Required in production for the external send API. Instance-specific keys also work.
GATEWAY_API_KEY=replace-with-a-long-random-admin-api-key
ALLOW_INSECURE_API=false
DASHBOARD_PASSWORD=replace-with-a-strong-dashboard-password
AUTH_SECRET=replace-with-at-least-32-random-characters

MAX_INBOUND_MEDIA_BYTES=20971520
MAX_OUTBOUND_MEDIA_BYTES=26214400
WEBHOOK_TIMEOUT_MS=15000
MEDIA_FETCH_TIMEOUT_MS=20000
MEDIA_ALLOWED_HOSTS=
BAILEYS_LOG_LEVEL=warn
DATA_RETENTION_DAYS=30
MAINTENANCE_INTERVAL_MS=21600000
