# Optional: where the local SQLite database is stored
SQLITE_DB_PATH=./data/gateway.db

# Optional: where WhatsApp session files are stored
WHATSAPP_SESSION_ROOT=./data/whatsapp-sessions

# Required for n8n/cloud AI agents to download media.
# Use your public app URL, ngrok URL, Cloudflare Tunnel URL, or VPS domain.
APP_BASE_URL=http://localhost:3000

# Optional: used only if you store encrypted webhook secrets
ENCRYPTION_KEY=exactly-32-characters-long-key!!
